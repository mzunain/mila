# =============================================================================
# Mila — local config.
#
# Copy this file to `.env` and fill in the values. Never commit a real `.env`.
# Docker compose reads `infra/.env` (cd to infra/) OR the shell env. The values
# below are what you need for both:
#   - running the full stack via `docker compose up` (in infra/)
#   - running pieces locally with `pnpm dev`
# =============================================================================

NODE_ENV=development

# --- Web (Next.js) -----------------------------------------------------------
# Internal URL the embedded Next.js server uses to reach the API on the same
# machine. For docker-compose this stays localhost because Next runs outside
# the compose stack (in the Electron shell or `pnpm dev:web`).
MILA_API_INTERNAL_URL=http://localhost:4000
NEXT_PUBLIC_API_WS_URL=ws://localhost:4000/meetings/live

# --- API (NestJS) ------------------------------------------------------------
API_PORT=4000
# Generate one with: openssl rand -hex 48
JWT_SECRET=replace-with-a-long-random-secret
# For docker-compose the API uses `postgresql://mila:mila@postgres:5432/mila`
# internally. The line below is for running Nest on the host (Postgres exposed
# on 15432 by infra/docker-compose.override.yml to avoid clashing with a local
# Postgres on 5432).
DATABASE_URL=postgresql://mila:mila@localhost:15432/mila
REDIS_URL=redis://localhost:6379
WEB_ORIGIN=http://localhost:3000

# --- ASR (speech-to-text) ----------------------------------------------------
# `mock` returns canned text. `http` calls the local faster-whisper worker.
ASR_PROVIDER=http
ASR_BASE_URL=http://127.0.0.1:9000
# tiny|base|small|medium|large-v3 — bigger = more accurate, slower, more RAM.
WHISPER_MODEL=small

# --- LLM (chat + notes) ------------------------------------------------------
# Default chain: Google Gemini → OpenRouter free tier → NVIDIA NIM free.
# At least one key below MUST be populated for chat/notes to work.
LLM_PROVIDER=google
LLM_MODEL=google/gemini-2.5-flash
LLM_FALLBACK_MODELS=google/gemini-2.5-flash-lite,openrouter/z-ai/glm-4.5-air:free,openrouter/qwen/qwen3-next-80b-a3b-instruct:free,nvidia_nim/meta/llama-3.3-70b-instruct
LLM_LIVE_NOTES_ENABLED=true
LLM_TIMEOUT_MS=45000
LLM_TRANSCRIPT_MAX_CHARS=16000
LLM_APP_URL=http://localhost:3002
FREE_CLAUDE_ENV_PATH=~/.config/free-claude-code/.env

# Generic OpenAI-compatible (only used when LLM_PROVIDER=openai-compatible).
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=

# --- Provider keys -----------------------------------------------------------
# Get keys from each provider's console. Leave blank to disable that provider.

# Google Gemini — https://aistudio.google.com/apikey
GOOGLE_API_KEY=
GOOGLE_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai

# OpenRouter — https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# NVIDIA NIM — https://build.nvidia.com
NVIDIA_NIM_API_KEY=
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1

# DeepSeek — https://platform.deepseek.com (cheap, not free)
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# --- Object storage (audio uploads) -----------------------------------------
# Any S3-compatible endpoint. Leave blank to disable upload features.
S3_ENDPOINT=
S3_REGION=local
S3_BUCKET=mila-audio
S3_ACCESS_KEY=
S3_SECRET_KEY=
