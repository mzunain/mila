{
  "name": "@mila/electron",
  "version": "0.1.0",
  "private": true,
  "description": "MILA cross-platform desktop shell (macOS, Windows, Linux).",
  "main": "dist/main.js",
  "author": {
    "name": "Mila",
    "email": "hello@mila.app"
  },
  "scripts": {
    "clean": "rimraf dist out",
    "build:ts": "tsc -p tsconfig.json",
    "build:web": "pnpm --filter @mila/web build",
    "prebundle": "pnpm clean && pnpm build:ts && pnpm build:web && node scripts/stage-web.mjs",
    "dev": "concurrently -k -n web,electron -c blue,magenta \"pnpm --filter @mila/web dev\" \"wait-on http://localhost:7300 && pnpm build:ts && cross-env NODE_ENV=development electron .\"",
    "start": "pnpm build:ts && electron .",
    "dist": "pnpm prebundle && electron-builder",
    "dist:mac": "pnpm prebundle && electron-builder --mac",
    "dist:win": "pnpm prebundle && electron-builder --win",
    "dist:linux": "pnpm prebundle && electron-builder --linux",
    "dist:all": "pnpm prebundle && electron-builder -mwl",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "pnpm build:ts && node --test dist/*.test.js"
  },
  "dependencies": {
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "rimraf": "^6.0.1",
    "typescript": "^5.6.3",
    "wait-on": "^8.0.1"
  }
}
