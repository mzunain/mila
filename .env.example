# Shared
NODE_ENV=development

# Web
MILA_API_INTERNAL_URL=http://localhost:4000
NEXT_PUBLIC_API_WS_URL=ws://localhost:4000/meetings/live

# API
API_PORT=4000
JWT_SECRET=replace-with-a-long-random-secret
DATABASE_URL=postgresql://mila:mila@localhost:5432/mila
REDIS_URL=redis://localhost:6379

# AI provider selection: mock | http
ASR_PROVIDER=mock
ASR_BASE_URL=http://localhost:9000
WHISPER_MODEL=small

# LLM notes provider selection: mock | free-claude | openrouter | nvidia_nim | ollama | lmstudio | llamacpp | openai-compatible
# - free-claude reads MODEL, NVIDIA_NIM_API_KEY, OPENROUTER_API_KEY, and local
#   OpenAI-compatible URLs from FREE_CLAUDE_ENV_PATH without copying secrets here.
# - openrouter uses OPENROUTER_API_KEY + OpenRouter's OpenAI-compatible API.
# - nvidia_nim uses NVIDIA_NIM_API_KEY + NVIDIA's OpenAI-compatible API.
LLM_PROVIDER=free-claude
LLM_MODEL=openrouter/minimax/minimax-m2.5:free
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=
LLM_LIVE_NOTES_ENABLED=false
LLM_TIMEOUT_MS=45000
LLM_TRANSCRIPT_MAX_CHARS=16000
LLM_APP_URL=http://localhost:3002
FREE_CLAUDE_ENV_PATH=~/.config/free-claude-code/.env
OPENROUTER_API_KEY=
NVIDIA_NIM_API_KEY=
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Example free fallbacks verified on OpenRouter as of 2026-05-14:
# openrouter/minimax/minimax-m2.5:free,openrouter/qwen/qwen3-coder:free
LLM_FALLBACK_MODELS=openrouter/qwen/qwen3-coder:free

# Object storage abstraction. Use any S3-compatible provider.
S3_ENDPOINT=http://localhost:3900
S3_REGION=local
S3_BUCKET=mila-audio
S3_ACCESS_KEY=mila
S3_SECRET_KEY=mila-password
